############################################################
# CITADEL NEXUS BACKEND — MASTER TEST FILE
# Manual sequential test file
# Run top-to-bottom for a brand new clean test run.
# Replace placeholders only after the relevant step returns.
############################################################

############################################################
# ENVIRONMENT — LOCKED CONFIG
############################################################

@baseUrl = http://localhost:3000
@adminId = admin-001

############################################################
# ROLE IDS — LOCKED REFERENCE
# Do not edit unless backend mapping truly changes.
############################################################

@role_cnx_holder              = 1484138333788704878
@role_cnx_holder_tier_1       = 1486299725056446524
@role_cnx_holder_tier_2       = 1486299823257948191
@role_cnx_holder_tier_3       = 1486299865322491914
@role_temp_premium_alpha      = 1486300614957994054

############################################################
# RUN PLACEHOLDERS — REPLACE AS YOU PROGRESS
# Leave all of these untouched before starting a fresh run.
############################################################

# Main user flow
@userId                       = REPLACE_USER_ID
@entitlementId                = REPLACE_ENTITLEMENT_ID
@confirmedPayoutId            = REPLACE_CONFIRMED_PAYOUT_ID
@failurePayoutId              = REPLACE_FAILURE_PAYOUT_ID
@rejectionPayoutId            = REPLACE_REJECTION_PAYOUT_ID

# Step 8H clean verification success flow
@successUserId                = REPLACE_SUCCESS_USER_ID
@successAuditId               = REPLACE_SUCCESS_AUDIT_ID

# Step 8H clean verification failure flow
@failureUserId                = REPLACE_FAILURE_USER_ID
@failureAuditId               = REPLACE_FAILURE_AUDIT_ID

# Step 8I mutation flow
@mutationUserId               = REPLACE_MUTATION_USER_ID
@mutationAuditIdA             = REPLACE_MUTATION_AUDIT_ID_A
@mutationAuditIdB             = REPLACE_MUTATION_AUDIT_ID_B
@mutationAuditIdC             = REPLACE_MUTATION_AUDIT_ID_C

############################################################
# SECTION 0 — PRE-FLIGHT / HEALTH
############################################################

### 0.1 Root Health Check
GET {{baseUrl}}/

###

### 0.2 Token Info
GET {{baseUrl}}/token/info

###

############################################################
# SECTION 1 — MAIN USER FLOW
# GOAL:
#   - create primary user
#   - link discord
#   - bind wallet
#   - add XP
#   - inspect base state
############################################################

### 1.1 Create Main User
# Copy returned "id" into @userId above
POST {{baseUrl}}/user/create
Content-Type: application/json

{
  "username": "CitadelTest"
}

###

### 1.2 Link Discord For Main User
POST {{baseUrl}}/user/{{userId}}/discord
Content-Type: application/json

{
  "discordId": "123456789012345678",
  "discordTag": "CitadelUser#0001"
}

###

### 1.3 Bind Wallet For Main User
POST {{baseUrl}}/user/{{userId}}/wallet
Content-Type: application/json

{
  "wallet": "0.0.9999999"
}

###

### 1.4 Add XP To Main User
# 400 XP = solid baseline for later access / payout tests
POST {{baseUrl}}/user/{{userId}}/xp
Content-Type: application/json

{
  "amount": 400
}

###

### 1.5 Get Main User
GET {{baseUrl}}/user/{{userId}}

###

### 1.6 Get Main User Balance
GET {{baseUrl}}/user/{{userId}}/balance

###

### 1.7 Get Main User Access State
GET {{baseUrl}}/access/{{userId}}

###

### 1.8 Get All Access States
GET {{baseUrl}}/access

###

############################################################
# SECTION 2 — TEMP ACCESS / CNX SINK
# GOAL:
#   - purchase temp access
#   - confirm balance and access changes
############################################################

### 2.1 Purchase Temporary Access
# Copy returned "entitlementId" into @entitlementId above if present
POST {{baseUrl}}/temp-access/{{userId}}/purchase
Content-Type: application/json

{
  "accessType": "premium_alpha"
}

###

### 2.2 Get Access State After Temp Purchase
GET {{baseUrl}}/access/{{userId}}

###

### 2.3 Get Main User After Temp Purchase
GET {{baseUrl}}/user/{{userId}}

###

### 2.4 Get Main User Balance After Temp Purchase
GET {{baseUrl}}/user/{{userId}}/balance

###

