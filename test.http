############################################################
# PASS / FAIL CHECKLIST
############################################################

# SECTION 17 SUCCESS FLOW — PASS IF:
#   17.5 access shows isCnxHolder = true and holderTierInternal = 1
#   17.6 returns fresh auditRecord.id
#   17.8 returns verificationPassed = true
#   17.9 returns status = "verified"

# SECTION 18 FAILURE FLOW — PASS IF:
#   18.5 access shows isCnxHolder = true and holderTierInternal = 1
#   18.6 returns fresh auditRecord.id
#   18.8 returns verificationPassed = false
#   18.8 mismatch.missing includes {{role_cnx_holder_tier_1}}
#   18.9 returns status = "failed"

# SECTION 20 MUTATION FLOW — PASS IF:
#   20B.1 returns mutationApplied = true and auditStatusAfterMutation = "mutated"
#   20C.1 returns mutationApplied = false and auditStatusAfterMutation = "no_op"
#   20D.1 returns mutationApplied = true
#   20D.1 removedRoleIds includes {{role_cnx_holder_tier_3}}
#   20D.1 addedRoleIds includes {{role_cnx_holder_tier_1}}

# IMPORTANT:
#   If any execute-attempt or mutate test reuses an old user/audit unexpectedly,
#   stop and create a fresh user for that section.
############################################################