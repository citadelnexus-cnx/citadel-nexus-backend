generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                 @id @default(uuid())
  username         String                 @unique
  discordId        String?                @unique
  discordTag       String?
  wallet           String?
  xp               Int                    @default(0)
  level            Int                    @default(1)
  cnxBalance       Float                  @default(0)
  reservedCnx      Float                  @default(0)
  isVerified       Boolean                @default(false)
  payoutEligible   Boolean                @default(false)
  joinedAt         DateTime               @default(now())
  lastActiveAt     DateTime               @default(now())
  rewardLog        Json                   @default("[]")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  accessState      AccessState?
  ascensionProfile AscensionProfile?
  audits           DiscordRoleSyncAudit[]
  entitlements     Entitlement[]
}

model AccessState {
  id                  String    @id @default(uuid())
  userId              String    @unique
  tier                String
  active              Boolean   @default(true)
  isCnxHolder         Boolean   @default(false)
  holderTierInternal  Int       @default(0)
  xpBoost             Float     @default(0)
  cooldownReduction   Float     @default(0)
  tempAccessType      String?
  tempAccessExpiresAt DateTime?
  lastEvaluatedAt     DateTime  @default(now())
  lastRoleSyncAt      DateTime?
  updatedAt           DateTime  @updatedAt
  createdAt           DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Entitlement {
  id              String   @id @default(uuid())
  userId          String
  entitlementType String
  entitlementKey  String
  status          String
  source          String
  grantedAt       DateTime @default(now())
  expiresAt       DateTime?
  updatedAt       DateTime @updatedAt
  metadataJson    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, grantedAt])
  @@index([status, expiresAt])
}

model DiscordRoleSyncAudit {
  id                        String   @id @default(uuid())
  userId                    String
  contractVersion           String
  executionSource           String
  status                    String
  canExecute                Boolean
  reasonsBlocked            String[]
  warnings                  String[]
  unsupportedTempAccessType String?
  unresolvedRoleKeys        String[]
  desiredAddRoleIds         String[]
  desiredRemoveRoleIds      String[]
  currentMemberRoleIds      String[]
  finalMemberRoleIds        String[]
  payloadJson               String
  verificationPassed        Boolean?
  rollbackSnapshotJson      String?
  errorMessage              String?
  idempotencyKey            String   @unique
  executionHash             String   @unique
  rateLimitBucket           String
  executionDurationMs       Int?
  attemptCount              Int      @default(1)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AscensionProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  discordId         String?  @unique
  username          String
  guardian          String   @default("nova")
  stage             Int      @default(1)
  rank              String   @default("initiate")
  xp                Int      @default(0)
  level             Int      @default(1)
  nodeScore         Int      @default(0)
  sessionCount      Int      @default(0)
  missionsCompleted Int      @default(0)
  isLocked          Boolean  @default(false)
  lockReason        String?
  power             Int      @default(5)
  maxPower          Int      @default(10)
  credits           Int      @default(50)
  intel             Int      @default(10)
  lastClaimAt       DateTime?
  buildingsJson     Json     @default("{\"knowledge_core\":1,\"trade_hub\":1,\"power_reactor\":1,\"security_layer\":1}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stage, rank])
}

model AscensionPrizePool {
  id               String   @id @default(uuid())
  poolName         String   @unique @default("main")
  totalXpAvailable Int      @default(0)
  totalXpAdded     Int      @default(0)
  totalXpAwarded   Int      @default(0)
  totalXpRemoved   Int      @default(0)
  notes            String?
  seasonId         String?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model AscensionAdminAction {
  id             String   @id @default(uuid())
  adminUserId    String
  adminUsername  String?
  targetUserId   String?
  targetUsername String?
  actionType     String
  resourceType   String?
  amount         Int?
  valueBefore    Json?
  valueAfter     Json?
  reason         String
  metadataJson   Json?
  createdAt      DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([actionType, createdAt])
}

model AscensionAdminSnapshot {
  id             String   @id @default(uuid())
  actionId       String
  targetUserId   String
  snapshotType   String
  profileState   Json?
  inventoryState Json?
  createdAt      DateTime @default(now())

  @@index([actionId])
  @@index([targetUserId, createdAt])
}